# WSDC Data Pipeline configuration
# Copy to .env and fill in values. Never commit .env.

# --- Supabase (Postgres) ---
# From Supabase: Connect -> ORMs -> .env.local -> DATABASE_URL
# Session pooler (port 5432) is recommended for this pipeline.
# If the URL contains ?pgbouncer=true, leave it — apply.py strips it automatically.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-2.pooler.supabase.com:5432/postgres

# --- Geocoding ---
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- Parser settings ---
START_DANCER_ID=1
MAX_ATTEMPTS=5
TIMEOUT=10
MAX_RETRIES=3
VERIFY_SSL=true
