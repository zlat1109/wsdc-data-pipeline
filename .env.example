# WSDC Data Pipeline configuration
# Copy to .env and fill in values. Never commit .env (only .env.example as template).

# --- Supabase (Postgres) ---
# Local: Direct connection (IPv6). CI / GitHub Actions: use pooler — see docs/GITHUB_ACTIONS.md.

# Direct (local laptop)
DB_HOST=db.<your-project-ref>.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=<your-database-password>

# Pooler Transaction mode (GitHub Actions — IPv4; copy these to repo secrets)
# DB_HOST=aws-1-eu-west-2.pooler.supabase.com
# DB_PORT=6543
# DB_USER=postgres.<your-project-ref>

# Option A — full URI (only if password has no special characters like @ : #)
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-eu-west-2.pooler.supabase.com:6543/postgres

# --- Geocoding ---
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- Parser / probe settings ---
START_DANCER_ID=1
MAX_ATTEMPTS=5
PROBE_ANCHOR_ID=26410
PROBE_MAX_MISSES=5
PROBE_SCAN_DELAY=0.05
TIMEOUT=10
MAX_RETRIES=3
VERIFY_SSL=true
